# FastAPI project settings
PROJECT_NAME=FastAPI Template
PROJECT_SUMMARY=A template for FastAPI projects.
PROJECT_VERSION=1.0.0
PROJECT_TERMS_OF_SERVICE=https://example.com/terms

# Application settings
DEBUG=false

# Database settings (PostgreSQL)
POSTGRES_DB=fastapi_db
POSTGRES_USER=postgres
POSTGRES_HOST=fastapi-db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=your_password_here
POSTGRES_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
POSTGRES_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=redis
REDIS_DB_INDEX=0
REDIS_DSN=redis://${REDIS_USER}:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB_INDEX}

# Uvicorn settings
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8080